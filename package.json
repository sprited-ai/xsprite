{
  "name": "sprited",
  "version": "0.3.0",
  "description": "Generate 8-direction game character sprites with template-guided image models",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "sprited": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./toonout": {
      "browser": "./dist/web/toonout.js",
      "default": "./dist/node/toonout.js"
    },
    "./build": "./dist/node/build.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/core/index.ts src/node/build.ts src/node/toonout.ts src/web/toonout.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "sharp": "^0.35.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "onnxruntime-web": "^1.26.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16",
    "vitest": "^2.1.0"
  },
  "repository": "github:sprited-ai/sprited",
  "keywords": [
    "sprites",
    "game-assets",
    "ai",
    "pixel-art",
    "character-generation"
  ],
  "optionalDependencies": {
    "onnxruntime-node": "^1.26.0"
  },
  "peerDependencies": {
    "onnxruntime-web": ">=1.26.0"
  },
  "peerDependenciesMeta": {
    "onnxruntime-web": {
      "optional": true
    }
  }
}
